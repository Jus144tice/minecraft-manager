{
  "name": "minecraft-manager",
  "version": "1.0.0",
  "description": "Web-based Minecraft Forge server management panel",
  "license": "Apache-2.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "node --env-file=.env --watch server.js",
    "test": "node --test tests/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "npx playwright test",
    "validate": "npm run lint && npm run format:check && npm test"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "discord.js": "^14.18.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "marked": "^17.0.4",
    "node-cron": "^4.2.1",
    "openid-client": "^5.7.1",
    "pg": "^8.20.0",
    "ws": "^8.17.0",
    "yauzl": "^3.2.1",
    "yazl": "^3.3.1"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1"
  }
}
