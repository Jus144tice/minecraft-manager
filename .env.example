# Minecraft Manager — Environment Variables
# Copy this file to .env for local development (never commit .env).
# In production, set these in the systemd service file (see README).

# ---------------------------------------------------------------
# REQUIRED in production (non-demo) mode
# ---------------------------------------------------------------

# Random secret used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Set to "1" when running behind a reverse proxy (Nginx, Caddy, etc.)
# Enables: correct client IP detection, secure cookie flag
TRUST_PROXY=1

# ---------------------------------------------------------------
# OIDC Authentication (Google and/or Microsoft)
# At least one provider is recommended for production.
# ---------------------------------------------------------------

# Public base URL of the app — used to construct OIDC callback URLs.
# Must match exactly what is registered in Google/Microsoft app settings.
# Example: https://mc.example.com
APP_URL=https://mc.example.com

# Comma-separated list of emails allowed to log in.
# Leave empty to allow any successfully authenticated account (not recommended).
ALLOWED_EMAILS=you@gmail.com,family@outlook.com

# --- Google ---
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL to register: https://mc.example.com/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft ---
# Create at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Callback URL to register: https://mc.example.com/auth/callback/microsoft
# MICROSOFT_TENANT: "common" = personal + work/school accounts
#                   "consumers" = personal accounts only
#                   "<tenant-id>" = specific organisation only
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# ---------------------------------------------------------------
# Local password fallback (optional, lower security than OIDC)
# Used when OIDC providers are not configured, or as a backup.
# Rate-limited to 20 attempts per 15 minutes per IP.
# ---------------------------------------------------------------

# LOCAL_PASSWORD=your-password-here

# ---------------------------------------------------------------
# PostgreSQL (optional — enables persistent sessions, audit logs, and user management)
# ---------------------------------------------------------------
# When not set, the app runs without a database (sessions in-memory, audit to stdout only).
# Example: postgres://mcmanager:secretpass@localhost:5432/mcmanager
DATABASE_URL=postgres://user:password@localhost:5432/mcmanager

# ---------------------------------------------------------------
# Development only — not needed in production
# ---------------------------------------------------------------
# NODE_ENV=production
