{
  "demoMode": true,
  "serverPath": "/home/minecraft/server",
  "rconHost": "127.0.0.1",
  "rconPort": 25575,
  "rconPassword": "your-rcon-password-here",
  "webPort": 3000,
  "bindHost": "127.0.0.1",
  "launch": {
    "executable": "java",
    "args": [
      "-Xms2G",
      "-Xmx8G",
      "@user_jvm_args.txt",
      "@libraries/net/minecraftforge/forge/1.20.1-47.3.0/unix_args.txt",
      "nogui"
    ]
  },
  "minecraftVersion": "1.20.1",
  "modsFolder": "mods",
  "disabledModsFolder": "mods_disabled",
  "autoStart": false,
  "autoRestart": true,
  "tpsAlertThreshold": 18,
  "backupEnabled": true,
  "backupSchedule": "0 3 * * *",
  "backupPath": "/mnt/backups/minecraft",
  "maxBackups": 14,
  "notifications": {
    "webhookUrl": "",
    "events": [
      "SERVER_CRASH",
      "SERVER_AUTO_RESTART",
      "SERVER_START",
      "SERVER_STOP",
      "BACKUP_CREATE",
      "BACKUP_FAILED",
      "LAG_SPIKE",
      "PLAYER_BAN",
      "PLAYER_KICK"
    ]
  }
}
